# ===========================
# .agentignore
# ===========================
# Files and directories that AI coding assistants should NOT index
# or include in their context window. This keeps the AI focused on
# relevant source code and avoids wasting tokens on noise.

# ===========================
# Dependencies
# ===========================
node_modules/
.venv/
venv/
env/

# ===========================
# Build Artifacts
# ===========================
frontend/dist/
backend/dist/
build/
*.egg-info/

# ===========================
# Python Cache
# ===========================
__pycache__/
*.pyc
*.pyo
.mypy_cache/
.ruff_cache/

# ===========================
# Test & Coverage Reports
# ===========================
htmlcov/
coverage/
.coverage
.coverage.*
.pytest_cache/

# ===========================
# Environment & Secrets
# ===========================
.env
.env.*
!.env.example

# ===========================
# IDE / Editor
# ===========================
.vscode/
.idea/
*.swp
*.swo

# ===========================
# Git
# ===========================
.git/

# ===========================
# Docker
# ===========================
docker-compose.override.yml

# ===========================
# Terraform State (sensitive)
# ===========================
.terraform/
*.tfstate
*.tfstate.*
*.tfvars

# ===========================
# Alembic Migration Versions
# ===========================
# NOTE: NOT ignored. Workflows (create-migration.md) and prompts
# require the AI to inspect generated migration files in this directory.
# If context bloat becomes an issue, re-add this exclusion and update
# create-migration.md to rely solely on CLI output.

# ===========================
# Lock Files
# ===========================
# Machine-generated and consume large context windows.
# IMPORTANT: security-audit.md depends on dependency truth from these
# files. Since they are excluded here, that workflow must rely on CLI
# output (npm audit, pip-audit) rather than direct file inspection.
package-lock.json
yarn.lock
pnpm-lock.yaml

# ===========================
# Static / Media Uploads
# ===========================
frontend/public/uploads/
backend/static/uploads/

# ===========================
# Logs
# ===========================
*.log
logs/

# ===========================
# OS Files
# ===========================
.DS_Store
Thumbs.db
Desktop.ini
